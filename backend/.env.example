ENV=development
API_BASE_URL=http://localhost:8000
DATABASE_URL=sqlite+aiosqlite:///./documind.db
JWT_SECRET_KEY=replace-with-strong-secret
JWT_ACCESS_TOKEN_EXPIRES_HOURS=24
JWT_REFRESH_TOKEN_EXPIRES_DAYS=7
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:5173
GROQ_API_KEY=replace-with-groq-api-key
AWS_ACCESS_KEY_ID=replace-with-aws-access-key-id
AWS_SECRET_ACCESS_KEY=replace-with-aws-secret-access-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=replace-with-s3-bucket-name
CHROMA_HOST=localhost
CHROMA_PORT=8001
