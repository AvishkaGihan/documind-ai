# ==============================================================================
# DOCUMIND AI - ENVIRONMENT VARIABLES EXAMPLE
# Copy this file to .env and fill in the values
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. CORE APPLICATION SETTINGS
# ------------------------------------------------------------------------------
ENV=development
API_BASE_URL=http://localhost:8000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:5173

# ------------------------------------------------------------------------------
# 2. DATABASE CONFIGURATION
# ------------------------------------------------------------------------------
DATABASE_URL=sqlite+aiosqlite:///./documind.db

# ------------------------------------------------------------------------------
# 3. SECURITY & AUTHENTICATION (JWT)
# ------------------------------------------------------------------------------
JWT_SECRET_KEY=replace-with-strong-secret
JWT_ACCESS_TOKEN_EXPIRES_HOURS=24
JWT_REFRESH_TOKEN_EXPIRES_DAYS=7
PASSWORD_RESET_TOKEN_EXPIRES_MINUTES=30
PASSWORD_RESET_FRONTEND_URL=http://localhost:3000/reset-password

# ------------------------------------------------------------------------------
# 4. EXTERNAL APIs & SERVICES
# ------------------------------------------------------------------------------
# Groq API for LLM features
GROQ_API_KEY=replace-with-groq-api-key
GROQ_MODEL_NAME=llama-3.3-70b-versatile
GROQ_TIMEOUT_SECONDS=20
GROQ_MAX_RETRIES=2

# AWS S3 Storage for document uploads
AWS_ACCESS_KEY_ID=replace-with-aws-access-key-id
AWS_SECRET_ACCESS_KEY=replace-with-aws-secret-access-key
AWS_REGION=us-east-1
# DO NOT include s3:// or arn structures. Just the raw bucket name.
# Example: my-secure-documind-bucket-9876
S3_BUCKET_NAME=replace-with-s3-bucket-name

# ------------------------------------------------------------------------------
# 5. VECTOR DATABASE (CHROMA DB)
# ------------------------------------------------------------------------------
CHROMA_HOST=localhost
CHROMA_PORT=8001

# ------------------------------------------------------------------------------
# 6. EMAIL NOTIFICATIONS (SMTP)
# ------------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
